{
  "manifest_version": 3,
  "name": "Keryx Wallet",
  "version": "0.4.0",
  "description": "Client-side wallet for the Keryx Network (KRX). Create or import a wallet and track your balance — keys never leave your device.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Keryx Wallet",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "storage",
    "alarms",
    "clipboardWrite"
  ],
  "host_permissions": [
    "https://keryx-labs.com/*"
  ]
}
